{
  "expo": {
    "name": "Монитор подписок",
    "slug": "subscription-monitor",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.subscriptionmonitor",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#020617"
      },
      "package": "com.anonymous.subscriptionmonitor"
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-build-properties",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "EXPO_PUBLIC_API_BASE_URL": "http://192.168.0.54:8000/api/users",
      "EXPO_PUBLIC_API_BASE_URL_IP": "http://192.168.0.54:8000/api/users",
      "EXPO_PUBLIC_API_BASE_URL_LOCAL": "http://127.0.0.1:8000/api/users",
      "eas": {
        "projectId": "7a13f90c-0fef-4422-89b6-552f9ba3fca9"
      }
    }
  }
}
